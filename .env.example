# ===========================================
# BountyFeedHQ Configuration
# ===========================================
# Copy this file to .env and fill in your values
# For Railway: Set these as environment variables in the Railway dashboard

# Twitter/X API v2 Credentials
# Get these from https://developer.twitter.com/en/portal/dashboard
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Scraping Configuration
# How often to scan (cron expression, default: every 30 minutes)
SCAN_CRON=*/30 * * * *

# Minimum viral score to draft a tweet (0-100)
MIN_VIRAL_SCORE=40

# Maximum tweets per day
# Note: Twitter Free API tier has a strict limit of 17 posts per 24 hours.
# Keep this around 10-15 to avoid hitting the rate limit.
MAX_TWEETS_PER_DAY=10

# Auto-post mode (true = post automatically, false = draft only)
AUTO_POST=true

# Telegram Channel Integration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=@your_telegram_channel_or_chat_id

# Groq LLM Configuration (Optional, for smart scoring & custom copywriting)
# Get a free/cheap key from https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Force Recalculation (Set true once to wipe scores/drafts and run LLM scoring on all old data)
FORCE_RESCORE=false

# Database path (relative to project root)
DB_PATH=./data/bounties.db

# Playwright browser settings
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Content safety: extra blocked keywords (comma-separated)
EXTRA_BLOCKED_KEYWORDS=

# Pump.fun GO URLs
BOUNTIES_URL=https://pump.fun/go/bounties
SUBMISSIONS_URL=https://pump.fun/go/submissions

